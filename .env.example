# Pick ONE free provider (Gemini recommended):
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional offline (install Ollama separately):
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Force mock mode (no external calls):
USE_MOCK_HISTORY=true

# Required by Nominatim usage policy:
NOMINATIM_USER_AGENT=history-viewer/1.0 (your@email.com)
